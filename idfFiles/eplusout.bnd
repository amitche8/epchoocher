Program Version,EnergyPlus, Version 25.1.0-68a4a7c774, YMD=2026.05.07 14:54
! This file shows details about the branches, nodes, and other
! elements of the flow connections.
! This file is intended for use in "debugging" potential problems
! that may also be detected by the program, but may be more easily
! identified by "eye".
! This file is also intended to support software which draws a
! schematic diagram of the HVAC system.
! ===============================================================
! #Nodes,<Number of Unique Nodes>
 #Nodes,9
! <Node>,<NodeNumber>,<Node Name>,<Node Fluid Type>,<# Times Node Referenced After Definition>
 Node,1,BLOCK TWO STOREY STOREY 0 ZONE AIR NODE,Air,0
 Node,2,BLOCK TWO STOREY STOREY 0 IDEAL LOADS SUPPLY INLET,Air,1
 Node,3,BLOCK TWO STOREY STOREY 0 RETURN OUTLET,Air,0
 Node,4,BLOCK TWO STOREY STOREY 1 ZONE AIR NODE,Air,0
 Node,5,BLOCK TWO STOREY STOREY 1 IDEAL LOADS SUPPLY INLET,Air,1
 Node,6,BLOCK TWO STOREY STOREY 1 RETURN OUTLET,Air,0
 Node,7,BLOCK ONE STOREY STOREY 0 ZONE AIR NODE,Air,0
 Node,8,BLOCK ONE STOREY STOREY 0 IDEAL LOADS SUPPLY INLET,Air,1
 Node,9,BLOCK ONE STOREY STOREY 0 RETURN OUTLET,Air,0
! ===============================================================
! Suspicious nodes have 0 references.  It is normal for some nodes, however.
! Listing nodes with 0 references (culled from previous list):
! <Suspicious Node>,<NodeNumber>,<Node Name>,<Node Fluid Type>,<# Times Node Referenced After Definition>
 Suspicious Node,1,BLOCK TWO STOREY STOREY 0 ZONE AIR NODE,Air,0
 Suspicious Node,3,BLOCK TWO STOREY STOREY 0 RETURN OUTLET,Air,0
 Suspicious Node,4,BLOCK TWO STOREY STOREY 1 ZONE AIR NODE,Air,0
 Suspicious Node,6,BLOCK TWO STOREY STOREY 1 RETURN OUTLET,Air,0
 Suspicious Node,7,BLOCK ONE STOREY STOREY 0 ZONE AIR NODE,Air,0
 Suspicious Node,9,BLOCK ONE STOREY STOREY 0 RETURN OUTLET,Air,0
! ===============================================================
! <#Branch Lists>,<Number of Branch Lists>
 #Branch Lists,0
! <Branch List>,<Branch List Count>,<Branch List Name>,<Loop Name>,<Loop Type>,<Number of Branches>
! <Branch>,<Branch Count>,<Branch Name>,<Loop Name>,<Loop Type>,<Branch Inlet Node Name>,<Branch Outlet Node Name>
